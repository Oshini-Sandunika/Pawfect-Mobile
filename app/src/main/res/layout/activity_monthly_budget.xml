<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF7F2"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="94dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="24dp"
            android:paddingEnd="18dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Pawfect Logo"
                android:scaleType="centerInside"
                android:src="@drawable/pawfect_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pawfect"
                    android:textColor="#5B3A2E"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Where paws meet their perfect match"
                    android:textColor="#8A746A"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/circle_light_button"
                android:gravity="center"
                android:text="×"
                android:backgroundTint="@null"
                android:textColor="#4E342E"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Title Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EFEAE6"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Monthly Pet Care Cost Calculator"
                android:textColor="#4E342E"
                android:textSize="27sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Estimate monthly and yearly care costs based on pet type, breed, age, food quality, vet care, and add-ons."
                android:textColor="#5F5F66"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Pet Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                card_view:cardBackgroundColor="#FFFFFF"
                card_view:cardCornerRadius="14dp"
                card_view:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pet Information"
                        android:textColor="#4E342E"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Pet Category"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerPetCategory"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:id="@+id/txtBreedLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Breed / Type"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerBreedType"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Pet Size"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerPetSize"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Age Group"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerAgeGroup"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Care Preferences Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                card_view:cardBackgroundColor="#FFFFFF"
                card_view:cardCornerRadius="14dp"
                card_view:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Care Preferences"
                        android:textColor="#4E342E"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Food Quality"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerFoodQuality"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Care Level"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerCareLevel"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Vet Saving Plan"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerVetPlan"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Add-ons Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                card_view:cardBackgroundColor="#FFFFFF"
                card_view:cardCornerRadius="14dp"
                card_view:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F4EFEB"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Optional Monthly Add-ons"
                        android:textColor="#4E342E"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/checkGrooming"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:buttonTint="#6B4638"
                        android:text="Grooming"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkInsurance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Pet insurance"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkToys"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Toys and treats"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkTraining"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Training / behavior support"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkMedicine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Medicine / supplements"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkCleaning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Litter / bedding / cleaning supplies"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkWalking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Dog walking / daycare"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkEmergency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Emergency fund saving"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Result Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                card_view:cardBackgroundColor="#FFFFFF"
                card_view:cardCornerRadius="14dp"
                card_view:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Monthly Cost Breakdown"
                        android:textColor="#4E342E"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtSelectedPet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Selected Pet:"
                        android:textColor="#6A5F5A"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/txtFoodCost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Food cost: LKR 0"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtRoutineCost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Routine care: LKR 0"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtVetCost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Vet saving: LKR 0"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtAddonCost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Optional add-ons: LKR 0"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtMonthlyTotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/result_box"
                        android:gravity="center"
                        android:padding="18dp"
                        android:text="Estimated Monthly Cost: LKR 0"
                        android:textColor="#E85D04"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtYearlyTotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="Estimated Yearly Cost: LKR 0"
                        android:textColor="#5B3A2E"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="These are estimated monthly costs. Actual expenses may vary depending on brand, clinic, breed, health condition, and location."
                        android:textColor="#7A6A62"
                        android:textSize="12sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/brown_rounded_button"
                android:text="Calculate Monthly Cost"
                android:backgroundTint="@null"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/light_rounded_button"
                android:text="Reset"
                android:backgroundTint="@null"
                android:textAllCaps="false"
                android:textColor="#5B3A2E"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>