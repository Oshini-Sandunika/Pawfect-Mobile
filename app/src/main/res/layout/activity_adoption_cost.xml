<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF7F2"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="94dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="24dp"
            android:paddingEnd="18dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Pawfect Logo"
                android:scaleType="centerInside"
                android:src="@drawable/pawfect_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pawfect"
                    android:textColor="#5B3A2E"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Where paws meet their perfect match"
                    android:textColor="#8A746A"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/circle_light_button"
                android:gravity="center"
                android:text="×"
                android:backgroundTint="@null"
                android:textColor="#4E342E"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Title Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EFEAE6"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="34dp"
            android:paddingEnd="24dp"
            android:paddingBottom="34dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Adoption Cost Estimator"
                android:textColor="#4E342E"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Estimate the initial cost of adopting your new pet based on pet type, breed, size, age, and care needs."
                android:textColor="#5F5F66"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Pet Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                card_view:cardBackgroundColor="#FFFFFF"
                card_view:cardCornerRadius="14dp"
                card_view:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pet Details"
                        android:textColor="#4E342E"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Pet Category"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerPetCategory"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:id="@+id/txtBreedLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Breed / Type"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerBreedType"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Pet Size"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerPetSize"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Age Group"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerAgeGroup"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Adoption Source"
                        android:textColor="#5B3A2E"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerAdoptionSource"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Care Options Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                card_view:cardBackgroundColor="#FFFFFF"
                card_view:cardCornerRadius="14dp"
                card_view:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Initial Care Options"
                        android:textColor="#4E342E"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/checkVaccination"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:buttonTint="#6B4638"
                        android:text="Vaccination package"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkAccessories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Starter accessories kit"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkMicrochip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Microchip / identification"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkVet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="First vet checkup"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkGrooming"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="First grooming session"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkSpayNeuter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Spay / neuter estimate"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkTraining"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="Basic training / settling support"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <CheckBox
                        android:id="@+id/checkInsurance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#6B4638"
                        android:text="First month insurance estimate"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Result Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                card_view:cardBackgroundColor="#FFFFFF"
                card_view:cardCornerRadius="14dp"
                card_view:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cost Breakdown"
                        android:textColor="#4E342E"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtSelectedPet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Selected Pet: Dog - Labrador Retriever"
                        android:textColor="#6A5F5A"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/txtAdoptionFee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Adoption fee: LKR 0"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtCareCost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Initial care options: LKR 0"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtAdjustment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Breed / age adjustment: LKR 0"
                        android:textColor="#4E342E"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtTotalCost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/result_box"
                        android:gravity="center"
                        android:padding="18dp"
                        android:text="Total Estimated Cost: LKR 0"
                        android:textColor="#E85D04"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="These are estimated costs. Actual expenses may vary depending on pet health, breed, clinic, and location."
                        android:textColor="#7A6A62"
                        android:textSize="12sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Buttons -->
            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/brown_rounded_button"
                android:text="Calculate Estimate"
                android:backgroundTint="@null"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/light_rounded_button"
                android:text="Reset"
                android:backgroundTint="@null"
                android:textAllCaps="false"
                android:textColor="#5B3A2E"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>