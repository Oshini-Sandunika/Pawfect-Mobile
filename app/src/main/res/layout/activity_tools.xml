<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FAF7F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Mobile Header -->
        <!-- Top Mobile Header -->
        <LinearLayout
            android:id="@+id/topHeader"
            android:layout_width="match_parent"
            android:layout_height="94dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="24dp"
            android:paddingEnd="18dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Pawfect Logo"
                android:scaleType="centerInside"
                android:src="@drawable/pawfect_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pawfect"
                    android:textColor="#5B3A2E"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Where paws meet their perfect match"
                    android:textColor="#8A746A"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☰"
                android:textColor="#5B3A2E"
                android:textSize="28sp" />

        </LinearLayout>

        <!-- Hero Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EFEAE6"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="36dp"
            android:paddingEnd="24dp"
            android:paddingBottom="42dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Pet Ownership Tools"
                android:textColor="#4E342E"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Planning for a new pet? Use our calculators and converters to get ready for your new family member."
                android:textColor="#5F5F66"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Cards Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Adoption Cost Estimator Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                card_view:cardCornerRadius="12dp"
                card_view:cardElevation="5dp"
                card_view:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰"
                        android:textSize="42sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="Adoption Cost Estimator"
                        android:textColor="#3E2723"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="Calculate the initial costs of adopting a pet, including vaccinations, supplies, and fees."
                        android:textColor="#3F2A24"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/btnAdoptionCost"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/brown_rounded_button"
                        android:minWidth="170dp"
                        android:text="Launch Calculator"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Monthly Care Budget Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                card_view:cardCornerRadius="12dp"
                card_view:cardElevation="5dp"
                card_view:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧮"
                        android:textSize="42sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="Monthly Care Budget"
                        android:textColor="#3E2723"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="Estimate the ongoing monthly expenses for food, grooming, vet care, and other needs."
                        android:textColor="#3F2A24"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/btnMonthlyBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/brown_rounded_button"
                        android:minWidth="170dp"
                        android:text="Calculate Budget"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Human Year Converter Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                card_view:cardCornerRadius="12dp"
                card_view:cardElevation="5dp"
                card_view:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏳"
                        android:textSize="42sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="Human Year Converter"
                        android:textColor="#3E2723"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="Wondering how old your dog or cat is in human years? Find out here."
                        android:textColor="#3F2A24"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/btnHumanYear"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/brown_rounded_button"
                        android:minWidth="170dp"
                        android:text="Convert Age"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>